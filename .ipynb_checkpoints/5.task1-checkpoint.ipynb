    "def table(n, i):\n",
    "    if i >10:\n",
    "        return \n",
    "\n",
    "    print(f\"{n}*{i} = {n*i}\")\n",
    "    \n",
    "    table (n,i+1)\n",
    "\n",
    "n = int(input(\"Enter a number\"))\n",
    "table(n, 1)\n",
    "        "
